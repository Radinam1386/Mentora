# Mentora environment configuration
# Copy this file to ".env" in the project root and fill in real values.
# settings.py loads it automatically (it is read from the repo root).

# ----- Django -----
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma separated. Use your domain(s) and/or server IP.
DJANGO_ALLOWED_HOSTS=mentoralearn.ir,www.mentoralearn.ir,78.157.54.151
# Needed for the Django admin login over HTTPS. Include the scheme.
DJANGO_CSRF_TRUSTED_ORIGINS=http://mentoralearn.ir,http://www.mentoralearn.ir

# ----- Planner LLM (used by Planning-Assistant/llm.py) -----
MODEL_API=your-openai-compatible-api-key
MODEL_BASE_URL=https://api.hormouz.net/v1
MODEL_NAME=x-ai/grok-4.3

# ----- RAG question solver (backend/api/question_solver.py) -----
# For one key, any one of these is accepted: GOOGLE_API_KEY / GEMINI_API_KEY / RAG_GOOGLE_API_KEY
GOOGLE_API_KEY=your-google-gemini-api-key
# For multiple keys, use comma/space/semicolon separated values; one is chosen randomly per attempt.
# RAG_API_KEYS is also accepted as a generic alias.
# RAG_GOOGLE_API_KEYS=key-one,key-two,key-three
# Number of retries after the first failed model call. RAG_MAX_RETRY is also accepted.
RAG_MAX_RETRIES=2
# Print RAG pipeline debug logs to the Django console without exposing full API keys.
RAG_DEBUG=False
# RAG_MODEL_NAME=gemma-4-31b-it
