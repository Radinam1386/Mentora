{
  "name": "mentora-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "cd frontend && npm install",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev -- --host 0.0.0.0 --port 3000",
    "dev:backend": "pip install -r backend/requirements.txt && python backend/manage.py makemigrations api && python backend/manage.py migrate && python backend/manage.py runserver 0.0.0.0:8000",
    "build": "cd frontend && npm run build",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd frontend && npm run preview -- --host 0.0.0.0 --port 3000",
    "start:backend": "python backend/manage.py runserver 0.0.0.0:8000",
    "lint": "cd frontend && npm run lint"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
